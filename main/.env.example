# AutoSec AI — Environment Variables
# Copy this file to .env and fill in your values

# Backend
HOST=0.0.0.0
PORT=8000

# Elasticsearch (optional — only needed with ELK stack)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=autosec-logs

# Auto-response thresholds (0–100)
CONFIDENCE_THRESHOLD_BLOCK=65
CONFIDENCE_THRESHOLD_CRITICAL=80

# Temp-block duration in minutes
TEMP_BLOCK_MINUTES=60

# Notifications (optional)
SLACK_WEBHOOK_URL=
PAGERDUTY_API_KEY=
